{
  "name": "@sentrix-labs/canonical-contracts",
  "version": "1.0.0",
  "description": "Canonical EVM contracts for Sentrix Chain (WSRX, Multicall3, SentrixSafe, TokenFactory). ABI artifacts published for SDK + dApp integration.",
  "license": "BUSL-1.1",
  "homepage": "https://github.com/sentrix-labs/canonical-contracts",
  "repository": {
    "type": "git",
